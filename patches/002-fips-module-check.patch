+func init() {
+       // If the host requires FIPS but this binary has no FIPS module
+       // (built with GOFIPS140=off), crash immediately. A binary without
+       // the FIPS module cannot be made compliant at runtime.
+       v := godebug.New("#fips140").Value()
+       if (v == "" || v == "off") && hostfips.Enabled() {
+               panic("fips140: host has FIPS mode enabled " +
+                       "(/proc/sys/crypto/fips_enabled) but this binary was " +
+                       "built with GOFIPS140=off and contains no FIPS module")
+       }
+}
