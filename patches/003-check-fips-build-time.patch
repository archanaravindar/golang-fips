From d5942b8cc26b010ba83f127e3610bd33422b28d4 Mon Sep 17 00:00:00 2001
From: Archana Ravindar <aravinda@redhat.com>
Date: Sat, 18 Jul 2026 15:40:58 +0530
Subject: [PATCH] check fips build time

---
 src/cmd/go/internal/load/godebug.go | 10 ++++++----
 1 file changed, 6 insertions(+), 4 deletions(-)

diff --git a/src/cmd/go/internal/load/godebug.go b/src/cmd/go/internal/load/godebug.go
index b5d4881b3b..e01c2213e4 100644
--- a/src/cmd/go/internal/load/godebug.go
+++ b/src/cmd/go/internal/load/godebug.go
@@ -10,11 +10,11 @@ import (
 	"go/build"
 	"internal/godebugs"
 	"maps"
+	"os"
 	"sort"
 	"strconv"
 	"strings"
 
-	"cmd/go/internal/fips140"
 	"cmd/go/internal/gover"
 	"cmd/go/internal/modload"
 )
@@ -74,9 +74,11 @@ func defaultGODEBUG(ld *modload.Loader, p *Package, directives, testDirectives,
 
 	// If GOFIPS140 is set to anything but "off",
 	// default to GODEBUG=fips140=auto.
-	if fips140.Enabled() {
-		m = map[string]string{"fips140": "auto"}
-	}
+	// If GOFIPS140 is set to anything other than "off", embed fips140=auto
+	// This should be checked at build time, not runtime host status
+	if os.Getenv("GOFIPS140") != "off" && os.Getenv("GOFIPS140") != "" {
+	      m = map[string]string{"fips140": "auto"}
+ 	}
 
 	// Add directives from main module go.mod.
 	for _, g := range ld.MainModules.Godebugs(ld) {
-- 
2.55.0

